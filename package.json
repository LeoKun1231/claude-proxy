{
  "name": "claude-proxy",
  "version": "1.0.0",
  "description": "Claude API 代理服务器 - 支持多 Provider 模型切换",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "package": "tsc && vite build && electron-packager . \"Claude Proxy\" --platform=win32 --arch=x64 --out=release-packager --overwrite --icon=public/icon.png --ignore=\"^/(src|release|release-packager|\\.git|\\.vscode|\\.claude|node_modules|electron|tsconfig|vite\\.config|build\\.log|log)\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.0",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.claude.proxy",
    "productName": "Claude Proxy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "public/icon.png"
    },
    "asar": true
  }
}