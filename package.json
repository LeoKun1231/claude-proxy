{
  "name": "claude-proxy",
  "version": "1.0.0",
  "description": "Claude API 代理桌面客户端 - 支持多 Provider 模型切换",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "dev:web:desktop": "vite",
    "build:web:desktop": "vite build",
    "browser:doctor": "bash scripts/browser-tools/doctor.sh",
    "browser:agent": "bash scripts/browser-tools/agent-browser.sh",
    "browser:agent:app": "npm run browser:agent -- --headed open http://127.0.0.1:5173",
    "browser:playwright": "node scripts/browser-tools/playwright-open.mjs",
    "browser:playwright:app": "npm run browser:playwright -- http://127.0.0.1:5173",
    "browser:chrome-mcp:browser": "bash scripts/browser-tools/chrome-mcp-browser.sh",
    "browser:chrome-mcp:app": "npm run browser:chrome-mcp:browser -- http://127.0.0.1:5173",
    "browser:chrome-mcp:server": "chrome-devtools-mcp --browserUrl http://127.0.0.1:9223",
    "build": "tauri build",
    "build:web": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-autostart": "^2.2.1",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.2",
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "chrome-devtools-mcp": "^0.20.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^7.3.1"
  }
}
