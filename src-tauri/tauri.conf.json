{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Proxy",
  "version": "1.0.0",
  "identifier": "com.leo.claude-proxy",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Proxy",
        "width": 1460,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
